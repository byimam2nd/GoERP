      "options": "Customer",
      "reqd": 1
    },
    {
      "name": "posting_date",
      "label": "Posting Date",
      "fieldtype": "Date",
      "reqd": 1
    },
    {
      "name": "due_date",
      "label": "Due Date",
      "fieldtype": "Date",
      "reqd": 1
    },
    {
      "name": "delivery_note",
      "label": "Delivery Note",
      "fieldtype": "Link",
      "options": "DeliveryNote"
    },
    {
      "name": "sales_order",
      "label": "Sales Order",
      "fieldtype": "Link",
      "options": "SalesOrder"
    },
    {
      "name": "company",
      "label": "Company",
      "fieldtype": "Link",
      "options": "Company",
      "reqd": 1
    },
    {
      "name": "items",
      "label": "Items",
      "fieldtype": "Table",
      "options": "SalesInvoiceItem",
      "reqd": 1
    },
    {
      "name": "total",
      "label": "Total",
