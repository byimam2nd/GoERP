      "label": "Net Total",
      "fieldtype": "Currency",
      "read_only": true
    },
    {
      "name": "taxes",
      "label": "Taxes and Charges",
      "fieldtype": "Table",
      "options": "SalesTaxesAndCharges"
    },
    {
      "name": "tax_total",
      "label": "Total Tax",
      "fieldtype": "Currency",
      "read_only": true
    },
    {
      "name": "grand_total",
      "label": "Grand Total",
      "fieldtype": "Currency",
      "read_only": true
    },
    {
      "name": "outstanding_amount",
      "label": "Outstanding Amount",
      "fieldtype": "Currency",
      "read_only": true
    },
    {
      "name": "invoiced_qty",
      "label": "Invoiced Qty",
      "fieldtype": "Float",
      "read_only": true,
      "default": "0"
    },
    {
      "name": "pending_invoice_qty",
      "label": "Pending Invoice Qty",
      "fieldtype": "Float",
      "read_only": true
    }
