      "label": "Posting Date",
      "fieldtype": "Date",
      "required": true
    },
    {
      "name": "party_type",
      "label": "Party Type",
      "fieldtype": "Select",
      "options": "Customer\nSupplier",
      "required": true
    },
    {
      "name": "party",
      "label": "Party",
      "fieldtype": "Link",
      "options": "Customer",
      "required": true
    },
    {
      "name": "paid_to",
      "label": "Bank/Cash Account",
      "fieldtype": "Link",
      "options": "Account",
      "required": true
    },
    {
      "name": "paid_amount",
      "label": "Paid Amount",
